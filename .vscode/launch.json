    "version": "0.2.0",
    "configurations": [
        {
            "name": "my_first_app (android debug, no dds)",
            "cwd": "my_first_app",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "deviceId": "emulator-5554",
            "toolArgs": [
                "--no-dds"
            ]
        },
        {
            "name": "my_first_app (profile mode)",
            "cwd": "my_first_app",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "profile"
        },
        {
            "name": "my_first_app (release mode)",
            "cwd": "my_first_app",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "release"
        }
    ]
}
